BLOTATO_API_KEY=
ANTHROPIC_API_KEY=
PORT=4520

# --- Blotato worker (B4) ---
# Base host for the Blotato REST API (no MCP - see SPEC.md "Decision 2").
BLOTATO_API_BASE=https://backend.blotato.com
# Hard safety default: dry-run ON. Only '0' or 'false' makes the worker place
# real create-post/media-upload calls against Blotato. Treat unset as ON.
BLOTATO_DRY_RUN=1
# In-process worker (handoff + verify, 5-min interval). Only '0' or 'false'
# stops it from starting with the server. Treat unset as ON.
POSTDECK_WORKER=1
# NOTE: handoff_window_hours (default 48) is NOT an env var - it lives in the
# `settings` table in the SQLite DB (see src/worker.js getHandoffWindowHours),
# editable via the dashboard Settings view.

# --- Optional: sync state to a remote box (rsync over SSH) ---
# Where state/social-state.json is written locally (defaults to ./state).
POSTDECK_STATE_DIR=
# Off unless you set a target below. Set to '1' to enable the rsync.
POSTDECK_SYNC_ENABLED=0
# If you want the app to rsync social-state.json to a server, set the target as
# "user@host:/path/to/social.json" (or set the three parts individually).
POSTDECK_SYNC_TARGET=user@your-host.example.com:/path/to/state/social.json
POSTDECK_SYNC_USER=user
POSTDECK_SYNC_HOST=your-host.example.com
POSTDECK_SYNC_PATH=/path/to/state/social.json
# SSH private key used for the rsync (defaults to ~/.ssh/id_ed25519).
POSTDECK_SYNC_KEY=

# --- Idea capture from the road (B5) ---
# Inbox dir watched once per worker cycle for *.md/*.txt idea drops.
# Defaults to ./capture-inbox/ under this repo.
POSTDECK_CAPTURE_DIR=
